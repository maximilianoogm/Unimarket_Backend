// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
 
}

// 1. USUARIOS / ALUMNOS
model User {
  id            Int           @id @default(autoincrement())
  email         String        @unique
  password      String        
  nombre        String
  carrera       String        @default("Ingeniería")
  avatar        String        @default("https://images.unsplash.com/photo-1535713875002-d1d0cf377fde")
  whatsapp      String?       
  active        Boolean       @default(true)
  fechaRegistro String        
  
  productos     Product[]     @relation("ProductosPublicados") // Relación de autoría
  favoritos     Product[]     @relation("ProductosFavoritos")  // N:M para Favoritos
  mensajesEnviados   ChatMessage[] @relation("MensajesEnviados")   // Mensajes enviados desde la burbuja
  mensajesRecibidos  ChatMessage[] @relation("MensajesRecibidos")  // Mensajes recibidos en la burbuja
}

// 2. PRODUCTOS / ANUNCIOS EN VENTA
model Product {
  id               Int             @id @default(autoincrement())
  titulo           String
  descripcion      String
  precio           Float
  imagen           String          @default("https://via.placeholder.com/500")
  active           Boolean         @default(true)
  fechaPublicacion String
  rating           Float           @default(5.0)
  
  autorId          Int
  autor            User            @relation("ProductosPublicados", fields: [autorId], references: [id])
  
  categoryId       Int
  categoria        Category        @relation(fields: [categoryId], references: [id])
  
  detalles         ProductDetails?
  tags             Tag[]           @relation("TagProduct")
  
  usuariosFavorito User[]          @relation("ProductosFavoritos") // Extremo opuesto de Favoritos N:M
  mensajesChat     ChatMessage[]   // Mensajes asociados a la negociación de este ítem
}

// 3. CATEGORÍAS MODULARES
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  productos Product[]
}

// 4. DETALLES EXTENDIDOS (1:1)
model ProductDetails {
  id         Int     @id @default(autoincrement())
  estado     String  
  ciclo      Int     @default(1) 
  stock      Int     @default(1)
  productId  Int     @unique
  producto   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// 5. ETIQUETAS DE BÚSQUEDA (N:M)
model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  productos Product[] @relation("TagProduct")
}

// 6. MENSAJES DE LA BURBUJA DE CHAT (Modelo Simplificado)
model ChatMessage {
  id         Int     @id @default(autoincrement())
  contenido  String
  fechaEnvio String
  
  remitenteId Int
  remitente   User   @relation("MensajesEnviados", fields: [remitenteId], references: [id])

  destinatarioId Int
  destinatario   User @relation("MensajesRecibidos", fields: [destinatarioId], references: [id])
  
  productoId  Int
  producto    Product @relation(fields: [productoId], references: [id], onDelete: Cascade)
}